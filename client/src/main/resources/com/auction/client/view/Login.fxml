<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Light.Distant?>
<?import javafx.scene.effect.Lighting?>
<?import javafx.scene.effect.Shadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>

<BorderPane prefHeight="802.0" prefWidth="980.0" style="-fx-background-color: #0d0c08;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">

    <!-- ===================== TOP NAVBAR ===================== -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="53.0" prefWidth="1120.0" style="-fx-background-color: #0d0c08; -fx-border-color: #2a2510; -fx-border-width: 0 0 1 0; -fx-padding: 0 40;">
            <!-- Logo -->
            <Label style="-fx-text-fill: #f0b429; -fx-font-size: 22px; -fx-font-weight: bold; -fx-font-family: 'Georgia';" text="AUCTION PRO" />
            <HBox HBox.hgrow="ALWAYS" />
            <!-- Nav Links -->
            <HBox alignment="CENTER" spacing="36">
                <Label style="-fx-text-fill: #d4cdb8; -fx-font-size: 12px; -fx-font-family: 'Arial'; -fx-cursor: hand;" text="AUCTIONS" />
                <Label style="-fx-text-fill: #d4cdb8; -fx-font-size: 12px; -fx-font-family: 'Arial'; -fx-cursor: hand;" text="COLLECTIBLES" />
                <Label style="-fx-text-fill: #d4cdb8; -fx-font-size: 12px; -fx-font-family: 'Arial'; -fx-cursor: hand;" text="PRIVATE SALES" />
                <Label style="-fx-text-fill: #d4cdb8; -fx-font-size: 12px; -fx-font-family: 'Arial'; -fx-cursor: hand;" text="CONCIERGE" />
            </HBox>
            <HBox HBox.hgrow="ALWAYS" />
            <!-- Auth Buttons -->
            <HBox alignment="CENTER" spacing="16">
                <Label style="-fx-text-fill: #d4cdb8; -fx-font-size: 12px; -fx-font-family: 'Arial'; -fx-cursor: hand;" text="REGISTER" />
                <Button style="-fx-background-color: #f0b429; -fx-text-fill: #0d0c08; -fx-font-size: 12px;                                -fx-font-weight: bold; -fx-font-family: 'Arial'; -fx-padding: 8 22;                                -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;" text="LOGIN" />
            </HBox>
        </HBox>
    </top>

    <!-- ===================== CENTER CONTENT ===================== -->
    <center>
        <!-- Split layout: left dark + right image -->
        <HBox>
            <!-- Left: dark area with card centered -->
            <StackPane style="-fx-background-color: #0d0c08;" HBox.hgrow="ALWAYS">
            <ImageView fitHeight="658.0" fitWidth="1021.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../../../../../../../../bg.png" />
               </image>
               <effect>
                  <Lighting>
                     <bumpInput>
                        <Shadow />
                     </bumpInput>
                     <light>
                        <Light.Distant>
                           <color>
                              <Color red="0.378947377204895" green="0.36912280321121216" blue="0.36912280321121216" />
                           </color>
                        </Light.Distant>
                     </light>
                  </Lighting>
               </effect>
            </ImageView>
                <!-- Login Card -->
                <VBox alignment="CENTER" maxHeight="560" maxWidth="390" prefHeight="546.0" prefWidth="370.0" spacing="8.0" style="-fx-background-color: #161410; -fx-background-radius: 6;                              -fx-border-radius: 6; -fx-border-color: #2e2a1e; -fx-border-width: 1;                              -fx-padding: 48 48 40 48;">
               <ImageView fitHeight="64.0" fitWidth="96.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../../../../../../../../../logo.png" />
                  </image>
               </ImageView>

                    <!-- Title -->
                    <Label style="-fx-text-fill: #f5f0e6; -fx-font-size: 28px;                                   -fx-font-family: 'Georgia'; -fx-font-weight: bold;" text="WELCOME" />

                    <!-- Subtitle -->
                    <Label style="-fx-text-fill: #8a8272; -fx-font-size: 13px; -fx-font-family: 'Arial';" text="Enter your credentials to access the gallery." textAlignment="CENTER" wrapText="true" />
               <VBox prefHeight="50.0" prefWidth="293.0" spacing="10.0">
                  <children>
      
                                <!-- EMAIL LABEL -->
                          <Label style="-fx-text-fill: #a09880; -fx-font-size: 10px; -fx-font-family: 'Arial';                                   -fx-font-weight: bold; -fx-letter-spacing: 1.5;" text="EMAIL OR USERNAME">
                              <VBox.margin>
                                  <Insets bottom="6" />
                              </VBox.margin>
                          </Label>
      
                                                              <!-- Email Field -->
                          <TextField fx:id="emailField" prefHeight="76.0" prefWidth="293.0" promptText="collector@aureate.com" style="-fx-background-color: #1e1c15; -fx-text-fill: #f5f0e6;                                       -fx-prompt-text-fill: #5a5444; -fx-border-color: #2e2a1e;                                       -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;                                       -fx-padding: 12 14; -fx-font-size: 13px; -fx-font-family: 'Arial';">
                              <VBox.margin>
                                  <Insets bottom="20" />
                              </VBox.margin>
                          </TextField>
                  </children>
               </VBox>

                    <!-- PASSWORD row: label + forgot -->
                    <HBox alignment="CENTER_LEFT" prefHeight="0.0" prefWidth="293.0">
                        <Label style="-fx-text-fill: #a09880; -fx-font-size: 10px; -fx-font-family: 'Arial';                                       -fx-font-weight: bold; -fx-letter-spacing: 1.5;" text="PASSWORD" />
                        <HBox HBox.hgrow="ALWAYS" />
                        <Label fx:id="forgotPasswordLabel" style="-fx-text-fill: #f0b429; -fx-font-size: 11px;                                       -fx-font-family: 'Arial'; -fx-cursor: hand;" text="Forgot Password?" />
                    </HBox>

                    <!-- Password Field -->
                    <PasswordField fx:id="passwordField" prefHeight="44" promptText="••••••••" style="-fx-background-color: #1e1c15; -fx-text-fill: #f5f0e6;                                           -fx-prompt-text-fill: #5a5444; -fx-border-color: #2e2a1e;                                           -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;                                           -fx-padding: 12 14; -fx-font-size: 13px; -fx-font-family: 'Arial';">
                        <VBox.margin>
                            <Insets bottom="24" top="6" />
                        </VBox.margin>
                    </PasswordField>

                    <!-- Error label (hidden by default) -->
                    <Label fx:id="errorLabel" style="-fx-text-fill: #e05252; -fx-font-size: 12px; -fx-font-family: 'Arial';" text="" visible="false" wrapText="true">
                        <VBox.margin>
                            <Insets bottom="10" />
                        </VBox.margin>
                    </Label>

                    <!-- LOGIN Button -->
                    <Button fx:id="loginButton" onAction="#handleLogin" prefHeight="46" prefWidth="294" style="-fx-background-color: #f0b429; -fx-text-fill: #0d0c08;                                    -fx-font-size: 13px; -fx-font-weight: bold; -fx-font-family: 'Arial';                                    -fx-letter-spacing: 1.5; -fx-background-radius: 4;                                    -fx-border-radius: 4; -fx-cursor: hand;" text="LOGIN">
                        <VBox.margin>
                            <Insets bottom="24" />
                        </VBox.margin>
                    </Button>

                    <!-- Sign Up Link -->
                    <HBox alignment="CENTER" spacing="4">
                        <Label style="-fx-text-fill: #8a8272; -fx-font-size: 13px; -fx-font-family: 'Arial';" text="Don't have an account?" />
                        <Label fx:id="signUpLabel" style="-fx-text-fill: #f0b429; -fx-font-size: 13px;                                       -fx-font-family: 'Arial'; -fx-cursor: hand;" text="Sign Up" />
                    </HBox>
                    <VBox.margin>
                        <Insets bottom="6" />
                    </VBox.margin>
                    <VBox.margin>
                        <Insets bottom="32" />
                    </VBox.margin>

                </VBox>
            </StackPane>
        </HBox>
    </center>

    <!-- ===================== FOOTER ===================== -->
    <bottom>
        <VBox prefHeight="72.0" prefWidth="997.0" style="-fx-background-color: #080706; -fx-border-color: #1e1c12; -fx-border-width: 1 0 0 0;                      -fx-padding: 24 40;">
            <HBox alignment="CENTER_LEFT">
                <!-- Footer Logo -->
                <VBox spacing="4">
                    <Label style="-fx-text-fill: #f0b429; -fx-font-size: 13px;                                   -fx-font-family: 'Georgia'; -fx-font-weight: bold;" text="AUCTION LUXURY PRO" />
                    <Label style="-fx-text-fill: #4a4434; -fx-font-size: 10px; -fx-font-family: 'Arial';" text="© 2026 AUCTION LUXURY PRO. ALL RIGHTS RESERVED." />
                </VBox>
                <HBox HBox.hgrow="ALWAYS" />
                <!-- Footer Links -->
                <HBox alignment="CENTER" spacing="32">
                    <Label style="-fx-text-fill: #5a5444; -fx-font-size: 10px;                                   -fx-font-family: 'Arial'; -fx-cursor: hand;" text="TERMS OF SERVICE" />
                    <Label style="-fx-text-fill: #5a5444; -fx-font-size: 10px;                                   -fx-font-family: 'Arial'; -fx-cursor: hand;" text="PRIVACY POLICY" />
                    <Label style="-fx-text-fill: #5a5444; -fx-font-size: 10px;                                   -fx-font-family: 'Arial'; -fx-cursor: hand;" text="AUCTION RULES" />
                    <Label style="-fx-text-fill: #5a5444; -fx-font-size: 10px;                                   -fx-font-family: 'Arial'; -fx-cursor: hand;" text="CONTACT SUPPORT" />
                </HBox>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
